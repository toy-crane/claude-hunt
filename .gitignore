# dependencies
/node_modules
/.pnp
.pnp.*

# lockfiles — bun is the only package manager; a stale package-lock.json makes
# Vercel install with npm and hit peer-dep ERESOLVE. Keep bun.lock only.
/package-lock.json
/yarn.lock
/pnpm-lock.yaml
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude
.claude/worktrees

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files
.env*.local
supabase/.env

# typescript
*.tsbuildinfo
next-env.d.ts
.vercel

# playwright
/playwright-report/
/test-results/
/playwright/.cache/
/e2e/.auth/

# Sentry Config File
.env.sentry-build-plugin
.env.local
