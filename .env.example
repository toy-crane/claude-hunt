NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required server env. Service-role key for privileged actions that bypass
# RLS (e.g. account deletion). Validated at app boot via `shared/config/env.ts`.
# Locally: copy from `supabase status`. In production: set in the hosting provider.
SUPABASE_SECRET_KEY=

# Optional. Sentry DSN — set in Vercel for production. The SDK is disabled
# outside production builds, so leaving it unset locally is fine.
NEXT_PUBLIC_SENTRY_DSN=

# Optional. Local-only opt-in for GET /auth/dev-login — one-URL sign-in as a
# seeded account (for AI agents and e2e). The route requires the exact value
# "true" and additionally returns 404 on production builds and non-local
# Supabase URLs. Never set this in Vercel.
DEV_LOGIN_ENABLED=
