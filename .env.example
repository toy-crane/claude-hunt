NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required server env. Service-role key for privileged actions that bypass
# RLS (e.g. account deletion). Validated at app boot via `shared/config/env.ts`.
# Locally: copy from `supabase status`. In production: set in the hosting provider.
SUPABASE_SECRET_KEY=
