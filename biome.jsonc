{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/type-aware",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ],
  "files": {
    // Skill templates, agent definitions, and harness assets live under
    // .claude/. They're not production code and often contain inline
    // scripts written for readability rather than lint-cleanliness.
    "includes": ["!.claude"]
  },
  "linter": {
    "rules": {
      "correctness": {
        // Biome's noUnresolvedImports is still a nursery rule and produces
        // false positives for packages that rely on `package.json` `exports`
        // conditions or virtual/bundled modules — e.g. `react` (Suspense,
        // hooks), `next/font/google`, `next/server`, `@supabase/ssr`.
        // See https://github.com/biomejs/biome/issues/9143 and #6464.
        // `tsc` (wired into the pre-commit `typecheck` job) already performs
        // the same check accurately via `.d.ts`, so this rule is redundant
        // here and only blocks commits with false positives.
        "noUnresolvedImports": "off",
        // Biome 2.4.7 misreads FSD path aliases like @shared/config as
        // scoped NPM packages. tsc + bundler resolution already protect
        // against typos; this rule is redundant here.
        "noUndeclaredDependencies": "off",
        // ultracite/biome/type-aware promotes this to error, forcing
        // `@features/foo/index.ts`-style imports. Ecosystem convention is
        // implicit extensions (`from "@features/foo"`), which
        // moduleResolution:"bundler" + Next.js/Vite resolve fine. Turning
        // the rule off lets us drop verbose explicit suffixes repo-wide.
        "useImportExtensions": "off"
      },
      "performance": {
        // FSD's Public API convention requires each slice to expose
        // its surface via index.ts (a barrel). Next.js tree-shakes
        // these cleanly via modularizeImports-aware bundling.
        "noBarrelFile": "off"
      }
    }
  },
  "overrides": [
    {
      // Supabase-generated DB types file — regenerated by `gen:types`.
      // Do not lint or format; it gets overwritten every time.
      "includes": ["shared/api/supabase/types.ts"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    },
    {
      // shadcn/ui generated components must not be modified
      // (see .claude/rules/shadcn-guard.md). Relax rules that trigger
      // on shadcn's upstream style.
      "includes": ["components/ui/**", "shared/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off",
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
