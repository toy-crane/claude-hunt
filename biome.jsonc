{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/type-aware",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ],
  "linter": {
    "rules": {
      "correctness": {
        // next/font/google, next/server, react, @supabase/ssr etc.
        // cannot be statically resolved by Biome (virtual/bundled modules)
        "noUnresolvedImports": "warn",
        // Biome 2.4.7 misreads FSD path aliases like @shared/config as
        // scoped NPM packages. tsc + bundler resolution already protect
        // against typos; this rule is redundant here.
        "noUndeclaredDependencies": "off"
      },
      "performance": {
        // FSD's Public API convention requires each slice to expose
        // its surface via index.ts (a barrel). Next.js tree-shakes
        // these cleanly via modularizeImports-aware bundling.
        "noBarrelFile": "off"
      },
      "style": {
        // DB row types are generated by Supabase and live under
        // shared/api/supabase. Entities/<slice>/model/schema.ts
        // narrows them into domain types. Feature code must import
        // domain types from @entities/<slice>, never the raw DB file.
        // Exception: shared/api/supabase/{client,server,proxy}.ts
        // need the generic Database type (infrastructure glue).
        //
        // Limitation: Biome rules are global, so we cannot express
        // "allow from shared/api/supabase/*". Rely on review for
        // this exception. The rule is a speed bump, not a wall —
        // `supabase.from("table")` still returns typed rows without
        // an explicit Database import.
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@shared/api/supabase/types": "DB types are wrapped by entities. Import Profile etc. from @entities/<slice> instead.",
              "@shared/api/supabase/types.ts": "DB types are wrapped by entities. Import Profile etc. from @entities/<slice> instead."
            }
          }
        }
      }
    }
  },
  "overrides": [
    {
      // shadcn/ui generated components must not be modified
      // (see .claude/rules/shadcn-guard.md). Relax rules that trigger
      // on shadcn's upstream style.
      "includes": ["components/ui/**", "shared/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off",
            "noArrayIndexKey": "off"
          }
        }
      }
    },
    {
      // Infrastructure glue that genuinely needs the raw Database type
      // (generic Supabase clients). Entities and features must not.
      "includes": [
        "shared/api/supabase/client.ts",
        "shared/api/supabase/server.ts",
        "shared/api/supabase/proxy.ts",
        "entities/**/model/schema.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ]
}
