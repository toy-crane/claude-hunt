{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/type-aware",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ],
  "files": {
    // Skill templates, agent definitions, and harness assets live under
    // .claude/. They're not production code and often contain inline
    // scripts written for readability rather than lint-cleanliness.
    "includes": ["!.claude"]
  },
  "linter": {
    "rules": {
      "correctness": {
        // next/font/google, next/server, react, @supabase/ssr etc.
        // cannot be statically resolved by Biome (virtual/bundled modules)
        "noUnresolvedImports": "warn",
        // Biome 2.4.7 misreads FSD path aliases like @shared/config as
        // scoped NPM packages. tsc + bundler resolution already protect
        // against typos; this rule is redundant here.
        "noUndeclaredDependencies": "off"
      },
      "performance": {
        // FSD's Public API convention requires each slice to expose
        // its surface via index.ts (a barrel). Next.js tree-shakes
        // these cleanly via modularizeImports-aware bundling.
        "noBarrelFile": "off"
      }
    }
  },
  "overrides": [
    {
      // Supabase-generated DB types file — regenerated by `gen:types`.
      // Do not lint or format; it gets overwritten every time.
      "includes": ["shared/api/supabase/types.ts"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    },
    {
      // shadcn/ui generated components must not be modified
      // (see .claude/rules/shadcn-guard.md). Relax rules that trigger
      // on shadcn's upstream style.
      "includes": ["components/ui/**", "shared/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off",
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
